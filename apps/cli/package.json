{
  "name": "chatbotx-cli",
  "version": "0.1.0",
  "description": "ChatbotX CLI - Command line interface for the ChatbotX API",
  "main": "dist/index.cjs",
  "type": "module",
  "bin": {
    "chatbotx": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "dev:cli": "dotenv -e .env -- tsx src/index.ts",
    "publish": "pnpm build && pnpm publish --access public --no-git-checks",
    "start": "node ./dist/index.cjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "keywords": [
    "chatbotX",
    "cli",
    "scheduling",
    "automation",
    "ai-agent",
    "command-line"
  ],
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "~24.12.2",
    "@types/yargs": "^17.0.35",
    "dotenv-cli": "^11.0.0",
    "tsdown": "0.21.10",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
