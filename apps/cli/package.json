{
  "name": "chatbotx-cli",
  "version": "0.1.0",
  "description": "ChatbotX CLI - Command line interface for the ChatbotX API",
  "main": "dist/index.cjs",
  "type": "module",
  "bin": {
    "chatbotx": "./dist/index.cjs"
  },
  "scripts": {
    "dev": "dotenv -e .env -- tsx src/index.ts",
    "build": "tsdown",
    "start": "node ./dist/index.cjs",
    "publish": "pnpm build && pnpm publish --access public --no-git-checks"
  },
  "keywords": [
    "chatbotX",
    "cli",
    "scheduling",
    "automation",
    "ai-agent",
    "command-line"
  ],
  "dependencies": {
    "@chatbotx/public-apis": "workspace:*",
    "@t3-oss/env-core": "^0.13.10",
    "ky": "^1.14.3",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aha.chat/typescript-config": "workspace:*",
    "@types/yargs": "^17.0.35",
    "dotenv-cli": "^11.0.0",
    "tsdown": "0.21.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
