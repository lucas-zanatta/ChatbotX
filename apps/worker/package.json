{
  "name": "worker",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "dev": "concurrently pnpm:worker:*",
    "https": "pnpm dev",
    "schedule": "dotenv -e ../../.env -- tsx --watch src/schedule/worker.ts",
    "test": "vitest run --passWithNoTests",
    "test:domains": "tsx scripts/test-domains.ts",
    "test:watch": "vitest",
    "worker:ai-agent": "dotenv -e ../../.env -- tsx --watch src/ai-agent/worker.ts",
