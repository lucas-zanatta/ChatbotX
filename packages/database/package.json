{
  "name": "@chatbotx.io/database",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@chatbotx.io/encryption": "workspace:*",
    "@chatbotx.io/utils": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "drizzle-orm": "1.0.0-beta.22",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chatbotx.io/vitest-config": "workspace:*",
    "@types/node": "^24.10.4",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "1.0.0-beta.22",
    "esbuild": "^0.28.0",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:check": "dotenv -e ../../.env -- drizzle-kit up",
    "db:migrate": "dotenv -e ../../.env -- node ./scripts/run-migrations.mjs",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed/index.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "introspect": "dotenv -e ../../.env -- drizzle-kit introspect",
    "make:migration": "dotenv -e ../../.env -- ./scripts/make-migration.sh",
    "backfill:organization-credentials": "dotenv -e ../../.env -- tsx scripts/backfill-organization-credentials.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts",
    "./keys": "./src/keys.ts",
    "./enums": "./src/enums.ts",
    "./schema": "./src/schema/index.ts",
    "./errors": "./src/errors.ts",
    "./utils": "./src/utils.ts",
    "./partials": "./src/partials/index.ts"
  }
}
