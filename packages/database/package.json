{
  "name": "@aha.chat/database",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@clickhouse/client": "^1.11.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "drizzle-cuid2": "^2.2.0",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "pg": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aha.chat/typescript-config": "workspace:*",
    "@paralleldrive/cuid2": "^3.3.0",
    "@types/node": "^24.10.4",
    "@types/pg": "^8.18.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "1.0.0-beta.15-859cf75"
  },
  "scripts": {
    "introspect": "dotenv -e ../../.env -- drizzle-kit introspect",
    "make:migration": "dotenv -e ../../.env -- ./scripts/make-migration.sh",
    "migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "clickhouse:migrate": "dotenv -e ../../.env -- tsx src/clickhouse/run.ts",
    "clickhouse:refresh": "dotenv -e ../../.env -v CLICKHOUSE_MIGRATIONS_FORCE=1 -- tsx src/clickhouse/run.ts",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed/index.ts",
    "db:setup": "pnpm migrate && pnpm db:seed",
    "db:check": "dotenv -e ../../.env -- drizzle-kit check"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts",
    "./keys": "./src/keys.ts",
    "./enums": "./src/enums.ts",
    "./schema": "./src/drizzle/schema.ts",
    "./errors": "./src/errors.ts",
    "./clickhouse/client": "./src/clickhouse/client.ts"
  }
}
