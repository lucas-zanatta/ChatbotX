{
  "name": "@aha.chat/database",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@t3-oss/env-core": "^0.13.10",
    "drizzle-cuid2": "^2.2.0",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aha.chat/typescript-config": "workspace:*",
    "@paralleldrive/cuid2": "^3.3.0",
    "@types/node": "^24.10.4",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0"
  },
  "scripts": {
    "introspect": "dotenv -e ../../.env -- drizzle-kit introspect",
    "make:migration": "dotenv -e ../../.env -- ./scripts/make-migration.sh",
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed/index.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "db:check": "dotenv -e ../../.env -- drizzle-kit check"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts",
    "./keys": "./src/keys.ts",
    "./enums": "./src/enums.ts",
    "./schema": "./src/drizzle/schema/index.ts",
    "./errors": "./src/errors.ts",
    "./utils": "./src/utils.ts"
  }
}
