{
  "name": "@ahachat.ai/database",
  "version": "0.1.0",
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^6.3.1"
  },
  "devDependencies": {
    "@ahachat.ai/typescript-config": "workspace:*",
    "@faker-js/faker": "^9.4.0",
    "@types/node": "^22.13.1",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.3.1"
  },
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma migrate dev --create-only",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- npx ts-node prisma/seed.ts",
    "db:client": "dotenv -e ../../.env -- prisma generate",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --force"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
