generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["nativeDistinct"]
  engineType      = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String?
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?
  isAnonymous   Boolean @default(false)

  accounts                 Account[]
  activityLogs             ActivityLog[]
  chatbotMembers           ChatbotMember[]
  conversationParticipants ConversationParticipant[]
  logs                     Log[]
  sessions                 Session[]
  inboxTeamMembers         InboxTeamMember[]
  contactNotes             ContactNote[]
  assignedConversations    Conversation[]
  organizationMembers      OrganizationMember[]
  invitations              OrganizationInvitation[]
}

model Account {
  id                    String    @id @default(cuid(2))
  accountId             String
  providerId            String
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid(2))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Organization {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  slug         String?
  logo         String?
  metadata     String?
  domain       String?
  supportEmail String?
  settings     Json    @default("{}")

  organizationMembers     OrganizationMember[]
  organizationInvitations OrganizationInvitation[]
  chatbots                Chatbot[]

  @@unique([slug])
  @@index([domain])
}

model OrganizationMember {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrganizationInvitation {
  id        String   @id @default(cuid(2))
  email     String
  role      String?
  status    String
  expiresAt DateTime

  inviterId String
  user      User   @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Chatbot {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name            String
  defaultReply    String?
  targetCountry   String?
  defaultLanguage String  @default("en")
  accountTimezone String
  brandColor      String  @default("#016DFF")
  developmentMode Boolean @default(false)
  logo            String?
  plan            String  @default("free")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  activityLogs             ActivityLog[]
  aiAgents                 AIAgent[]
  aiAssistants             AIAssistant[]
  aiTriggers               AITrigger[]
  attachments              Attachment[]
  broadcasts               Broadcast[]
  chatbotMembers           ChatbotMember[]
  contacts                 Contact[]
  conversationParticipants ConversationParticipant[]
  conversations            Conversation[]
  fields                   Field[]
  flows                    Flow[]
  flowVersions             FlowVersion[]
  folders                  Folder[]
  inboxes                  Inbox[]
  inboxTeamMembers         InboxTeamMember[]
  inboxTeams               InboxTeam[]
  integrationWebchats      IntegrationWebchat[]
  integrationMessengers    IntegrationMessenger[]
  integrationZalos         IntegrationZalo[]
  integrationGoogleSheets  IntegrationGoogleSheets[]
  integrationOpenAIs       IntegrationOpenAI[]
  integrations             Integration[]
  integrationWhatsapps     IntegrationWhatsapp[]
  logs                     Log[]
  messages                 Message[]
  spreadsheets             Spreadsheet[]
  tags                     Tag[]
  automatedResponses       AutomatedResponse[]
  flowRuns                 FlowRun[]
  aiFiles                  AIFile[]
  aiFunctions              AIFunction[]
  aiMCPServers             AIMCPServer[]
  integrationGemini        IntegrationGemini?
  chatbotUsage             ChatbotUsage?
}

model ChatbotMember {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role                       ChatbotMemberRole
  isAdmin                    Boolean
  enableAnalytics            Boolean
  enableFlows                Boolean
  enableContacts             Boolean
  enableOnlyAssignedContacts Boolean
  enableEmailAndPhone        Boolean
  enableBroadcast            Boolean
  enableEcommerce            Boolean

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model InboxTeam {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  inboxTeamMembers      InboxTeamMember[]
  assignedConversations Conversation[]
}

model InboxTeamMember {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  inboxTeamId String
  inboxTeam   InboxTeam @relation(fields: [inboxTeamId], references: [id], onDelete: Cascade)

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  data   String
  action String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model Log {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logType LogType
  action  String
  detail  String
  url     String?

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
}

model Contact {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  avatar          String?
  phoneNumber     String?
  email           String?
  emailVerified   Boolean   @default(false)
  emailOptIn      Boolean   @default(false)
  firstName       String?
  lastName        String?
  gender          Gender
  source          String
  lastSeenAt      DateTime?
  sourceId        String?
  blockedAt       DateTime?
  enableBroadcast Boolean   @default(false)

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  broadcasts          ContactsOnBroadcasts[]
  conversation        Conversation?
  logs                Log[]
  tags                Tag[]
  contactNotes        ContactNote[]
  contactCustomFields ContactCustomField[]

  @@unique([chatbotId, sourceId])
}

model Folder {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name       String
  folderType FolderType
  parentId   String?
  chatbotId  String
  isTrash    Boolean    @default(false)
  paths      String[]   @default([])

  parent   Folder?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("ParentChild")
  chatbot  Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  tags     Tag[]
  fields   Field[]
  flows    Flow[]

  @@index([chatbotId])
  @@index([parentId])
}

model Tag {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name            String
  folderId        String?
  syncToMessenger Boolean @default(false)

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  folder   Folder?   @relation(fields: [folderId], references: [id])
  contacts Contact[]

  @@unique([chatbotId, name])
  @@index([folderId])
}

model ContactInbox {
  contactId String
  inboxId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  sourceId  String // Id message of messenger or whatsapp, ...

  @@id([contactId, inboxId])
}

model Field {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name            String
  customFieldType CustomFieldType
  description     String?
  fieldType       FieldType
  value           String?
  showInInbox     Boolean

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id])

  contactCustomFields ContactCustomField[]
}

model Inbox {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inboxType InboxType
  sourceId  String

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  integrationWhatsapp  IntegrationWhatsapp?
  integrationWebchat   IntegrationWebchat?
  integrationMessenger IntegrationMessenger?
  integrationZalo      IntegrationZalo?

  messages      Message[]
  conversations Conversation[]

  @@unique([chatbotId, inboxType, sourceId])
  @@index([chatbotId])
}

model Conversation {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  liveChatEnabled        Boolean   @default(false)
  archivedAt             DateTime?
  sourceId               String?
  conversationAttributes Json?
  contactLastSeenAt      DateTime?
  agentLastSeenAt        DateTime?
  currentFlowRunId       String?
  lastActivityAt         DateTime  @default(now())
  followed               Boolean   @default(false)

  assignedUserId String?
  assignedUser   User?   @relation(fields: [assignedUserId], references: [id])

  assignedInboxTeamId String?
  assignedInboxTeam   InboxTeam? @relation(fields: [assignedInboxTeamId], references: [id])

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  contactId String  @unique
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  inboxId String
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade)

  messages                 Message[]
  conversationParticipants ConversationParticipant[]
  attachment               Attachment[]
  flowRuns                 FlowRun[]

  @@index([chatbotId, sourceId])
}

model ConversationParticipant {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([chatbotId])
  @@index([conversationId])
}

model Message {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content           String?
  contentAttributes Json?
  messageType       MessageType
  contentType       ContentType
  senderType        SenderType
  senderId          String?
  sourceId          String?

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  inboxId        String
  inbox          Inbox        @relation(fields: [inboxId], references: [id], onDelete: Cascade)

  attachments Attachment[]

  @@unique([chatbotId, sourceId])
  @@index([chatbotId])
  @@index([conversationId])
  @@index([inboxId])
  @@index([senderType, senderId])
}

model Attachment {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fileType      FileType
  sourceId      String?
  mimeType      String
  width         Int?
  height        Int?
  size          Int      @default(0)
  thumbnailPath String?
  originPath    String
  name          String?

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
  @@index([messageId])
}

model Integration {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integrationType IntegrationType

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  openAI       IntegrationOpenAI?
  googleSheets IntegrationGoogleSheets?

  @@index([chatbotId])
}

model AIAgent {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  prompt      String?
  messages    Json[]
  isDefault   Boolean  @default(false)
  tools       String[]
  models      Json[]
  temperature Float
  maxTokens   Int

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  integrationOpenAIs IntegrationOpenAI[]
}

model AIAssistant {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  prompt        String
  model         String
  aiTriggerIds  String[]
  attachmentIds String[]
  temperature   Float

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  integrationOpenAI IntegrationOpenAI[]
}

model AITrigger {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  description  String?
  flowId       String?
  questions    Json[]
  finalMessage String?

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  integrationOpenAIs IntegrationOpenAI[]
}

model IntegrationOpenAI {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auth           Json
  autoReply      Boolean @default(true)
  autoReplyVoice Boolean @default(false)
  voice          String?
  prompt         String?
  model          String
  temperature    Float
  maxTokens      Int

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  integrationId String      @unique
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  aiTriggers AITrigger[]

  aiAssistantId String?
  aiAssistant   AIAssistant? @relation(fields: [aiAssistantId], references: [id])

  aiAgentId String?
  aiAgent   AIAgent? @relation(fields: [aiAgentId], references: [id])
}

model AIFile {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  path     String
  size     Int
  mimeType String

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model AIFunction {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  purpose       String?
  dataCollect   Json?
  outputMessage String?

  triggerFlowId String?
  triggerFlow   Flow?   @relation(fields: [triggerFlowId], references: [id])

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model AIMCPServer {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name           String
  url            String
  auth           Json
  availableTools Json
  selectedTools  String[]

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model IntegrationGoogleSheets {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auth Json

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  integrationId String      @unique
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model IntegrationWhatsapp {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auth          Json
  phoneNumberId String
  wabaId        String
  businessId    String
  name          String

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  inboxId String @unique
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  messageTemplates WhatsappMessageTemplate[]
  whatsappFlows    WhatsappFlow[]
}

model IntegrationGemini {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auth      Json?
  autoReply Boolean @default(false)

  chatbotId String  @unique
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model IntegrationMessenger {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auth   Json
  pageId String
  name   String

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  inboxId String @unique
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  fallbackFlowId String?
  fallbackFlow   Flow?   @relation(fields: [fallbackFlowId], references: [id])

  @@unique([pageId])
  @@index([chatbotId])
  @@index([fallbackFlowId])
}

model IntegrationZalo {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auth Json
  oaId String
  name String

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  inboxId String @unique
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  fallbackFlowId String?
  fallbackFlow   Flow?   @relation(fields: [fallbackFlowId], references: [id])

  @@index([chatbotId])
  @@index([fallbackFlowId])
}

model WhatsappMessageTemplate {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name                  String
  integrationWhatsappId String
  sourceId              String
  language              String
  category              String
  status                String

  integrationWhatsapp IntegrationWhatsapp @relation(fields: [integrationWhatsappId], references: [id], onDelete: Cascade)
}

model WhatsappFlow {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name                  String
  integrationWhatsappId String
  sourceId              String
  status                String
  isCompleted           Boolean

  integrationWhatsapp IntegrationWhatsapp @relation(fields: [integrationWhatsappId], references: [id], onDelete: Cascade)
}

model IntegrationWebchat {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auth                 Json
  name                 String
  enable               Boolean  @default(true)
  authorizedDomains    String[]
  conversationStarters Json[]
  persistentMenus      Json[]
  brandColor           String   @default("#007bff")
  hideHeader           Boolean  @default(false)
  showLogo             Boolean  @default(false)
  hideMessageInput     Boolean  @default(false)
  customCss            String?

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  inboxId String @unique
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  welcomeFlowId String?
  welcomeFlow   Flow?   @relation(fields: [welcomeFlowId], references: [id])

  @@index([chatbotId])
  @@index([inboxId])
  @@index([welcomeFlowId])
}

model Spreadsheet {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String
  url  String

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model Flow {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name             String
  active           Boolean @default(true)
  enableInInbox    Boolean @default(true)
  currentVersionId String?
  draftVersionId   String?

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id])

  flowVersions          FlowVersion[]
  broadcasts            Broadcast[]
  flowRuns              FlowRun[]
  aiFunctions           AIFunction[]
  integrationWebchats   IntegrationWebchat[]
  integrationMessengers IntegrationMessenger[]
  integrationZalos      IntegrationZalo[]
}

model FlowVersion {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodes       Json
  edges       Json
  isDraft     Boolean
  isLatest    Boolean @default(false)
  startNodeId String

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  flowId String
  flow   Flow   @relation(fields: [flowId], references: [id], onDelete: Cascade)

  flowRuns FlowRun[]
}

model FlowRun {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  flowId String
  flow   Flow   @relation(fields: [flowId], references: [id], onDelete: Cascade)

  flowVersionId String
  flowVersion   FlowVersion @relation(fields: [flowVersionId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Broadcast {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  inboxType     InboxType?
  subaction     BroadcastSubaction?
  status        BroadcastStatus
  schedulesType BroadcastSchedulesType
  schedulesAt   DateTime
  conditions    Json?

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  flowId String
  flow   Flow   @relation(fields: [flowId], references: [id], onDelete: Cascade)

  contacts ContactsOnBroadcasts[]

  @@index([chatbotId])
  @@index([flowId])
  @@index([schedulesAt])
}

model ContactsOnBroadcasts {
  broadcastId String
  contactId   String
  sent        Boolean @default(false)
  delivered   Boolean @default(false)
  seen        Boolean @default(false)
  clicked     Boolean @default(false)
  failed      Boolean @default(false)

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([broadcastId, contactId])
}

model AutomatedResponse {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userMessages String[]
  folderId     String?
  replies      Json[]
  status       Boolean

  chatbotId String
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
}

model ContactNote {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content String

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model ContactCustomField {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  value String

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  customFieldId String
  customField   Field  @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, customFieldId])
}

model ChatbotUsage {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactsCount Int @default(0)
  maxContacts   Int @default(0)

  chatbotId String  @unique
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

