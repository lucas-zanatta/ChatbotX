// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["nativeDistinct"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id     String @id @default(cuid(2))
  name   String
  domain String @unique

  users    User[]
  chatbots Chatbot[]
}

model User {
  id            String    @id @default(cuid(2))
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  workspaceId   String

  accounts                 Account[]
  activityLogs             ActivityLog[]
  assignedContacts         Contact[]                 @relation("AssignedUser")
  chatbotMembers           ChatbotMember[]
  conversationParticipants ConversationParticipant[]
  logs                     Log[]                     @relation("ExecutorUser")
  sessions                 Session[]
  inboxTeamMembers         InboxTeamMember[]
  workspace                Workspace                 @relation(fields: [workspaceId], references: [id])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Chatbot {
  id              String      @id @default(cuid(2))
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  name            String
  defaultReply    String?
  targetCountry   String?
  defaultLanguage String      @default("en")
  accountTimezone String
  brandColor      String      @default("#016DFF")
  developmentMode Boolean     @default(false)
  logo            String?
  plan            ChatbotPlan
  workspaceId     String

  activityLogs             ActivityLog[]
  aiAgents                 AIAgent[]
  aiAssistants             AIAssistant[]
  aiTriggers               AITrigger[]
  attachments              Attachment[]
  broadcasts               Broadcast[]
  channelWebWidgets        ChannelWebWidget[]
  chatbotMembers           ChatbotMember[]
  contacts                 Contact[]
  conversationParticipants ConversationParticipant[]
  conversations            Conversation[]
  fields                   Field[]
  flows                    Flow[]
  flowVersions             FlowVersion[]
  folders                  Folder[]
  inboxes                  Inbox[]
  inboxTeamMembers         InboxTeamMember[]
  inboxTeams               InboxTeam[]
  integrationChatWidgets   IntegrationChatWidget[]
  integrationGoogleSheets  IntegrationGoogleSheets[]
  integrationOpenAIs       IntegrationOpenAI[]
  integrations             Integration[]
  integrationWhatsapps     IntegrationWhatsapp[]
  logs                     Log[]
  messages                 Message[]
  spreadsheets             Spreadsheet[]
  tags                     Tag[]
  workspace                Workspace                 @relation(fields: [workspaceId], references: [id])
}

model ChatbotMember {
  id                         String            @id @default(cuid(2))
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  chatbotId                  String
  userId                     String
  role                       ChatbotMemberRole
  isAdmin                    Boolean
  enableAnalytics            Boolean
  enableFlows                Boolean
  enableContacts             Boolean
  enableOnlyAssignedContacts Boolean
  enableEmailAndPhone        Boolean
  enableBroadcast            Boolean
  enableEcommerce            Boolean

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model InboxTeam {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  name      String

  chatbot           Chatbot           @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  inxboxTeamMembers InboxTeamMember[]
  assignedContacts  Contact[]         @relation("AssignedTeam")
}

model InboxTeamMember {
  id          String @id @default(cuid(2))
  chatbotId   String
  inboxTeamId String
  userId      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  inboxTeam InboxTeam @relation(fields: [inboxTeamId], references: [id], onDelete: Cascade)
  chatbot   Chatbot   @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  userId    String
  data      String
  action    String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model Log {
  id           String        @id @default(cuid(2))
  createdAt    DateTime      @default(now())
  chatbotId    String
  logType      LogType
  action       String
  detail       String
  url          String?
  executorType ExecutorType?
  executorId   String?

  chatbot         Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  executorUser    User?    @relation("ExecutorUser", fields: [executorId], references: [id], map: "user_executorId")
  executorContact Contact? @relation("ExecutorContact", fields: [executorId], references: [id], map: "contact_executorId")
}

enum LogType {
  Error
  Audit
}

enum ExecutorType {
  User
  Contact
}

model Contact {
  id           String        @id @default(cuid(2))
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  avatar       String?
  chatbotId    String
  phoneNumber  String?
  email        String?
  firstName    String?
  lastName     String?
  gender       Gender
  source       String
  assignedType AssignedType?
  assignedId   String?
  lastSeenAt   DateTime?
  sourceId     String?

  assignedTeam InboxTeam?             @relation("AssignedTeam", fields: [assignedId], references: [id], map: "team_assignedId")
  assignedUser User?                  @relation("AssignedUser", fields: [assignedId], references: [id], map: "user_assignedId")
  broadcasts   ContactsOnBroadcasts[]
  chatbot      Chatbot                @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  conversation Conversation?
  logs         Log[]                  @relation("ExecutorContact")
  tags         Tag[]

  @@unique([chatbotId, sourceId])
}

model Folder {
  id         String     @id @default(cuid(2))
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  name       String
  folderType FolderType
  parentId   String?
  chatbotId  String
  isTrash    Boolean    @default(false)
  paths      String[]   @default([])

  parent   Folder?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("ParentChild")
  chatbot  Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  tags     Tag[]
  fields   Field[]
  flows    Flow[]

  @@index([chatbotId])
  @@index([parentId])
}

model Tag {
  id              String   @id @default(cuid(2))
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  name            String
  folderId        String?
  syncToMessenger Boolean
  chatbotId       String

  chatbot  Chatbot   @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  folder   Folder?   @relation(fields: [folderId], references: [id])
  contacts Contact[]

  @@index([folderId])
}

model ContactInbox {
  contactId String
  inboxId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  sourceId  String // Id message of messenger or whatsapp, ...

  @@id([contactId, inboxId])
}

model WebWidgetTemplate {
  id   String @id @default(cuid(2))
  name String

  channelWebWidgets ChannelWebWidget[]
}

model ChannelWebWidget {
  id                  String   @id @default(cuid(2))
  chatbotId           String
  authorizedDomains   String[]
  webWidgetTemplateId String
  brandColor          String   @default("#007bff")
  showHeader          Boolean  @default(true)
  showPersonalLogo    Boolean  @default(false)
  showMessageInput    Boolean  @default(true)
  customizeStyles     String?

  // welcomeFlow Flow? @relation(fields: [welcomeFlowId], references: [id])
  chatbot  Chatbot           @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  template WebWidgetTemplate @relation(fields: [webWidgetTemplateId], references: [id])

  @@index([chatbotId])
  @@index([webWidgetTemplateId])
}

model Field {
  id              String          @id @default(cuid(2))
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  name            String
  customFieldType CustomFieldType
  description     String?
  folderId        String?
  fieldType       FieldType
  value           String?
  showInInbox     Boolean
  chatbotId       String

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id])
}

model Inbox {
  id        String    @id @default(cuid(2))
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  chatbotId String
  inboxType InboxType

  integrationWhatsapp   IntegrationWhatsapp?
  integrationChatWidget IntegrationChatWidget?
  messages              Message[]
  chatbot               Chatbot                @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
}

model Conversation {
  id                     String    @id @default(cuid(2))
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  chatbotId              String
  contactId              String    @unique
  inboxType              InboxType
  liveChatEnabled        Boolean   @default(false)
  followed               Boolean   @default(false)
  archivedAt             DateTime?
  blockedAt              DateTime?
  sourceId               String?
  conversationAttributes Json?
  contactLastSeenAt      DateTime?
  agentLastSeenAt        DateTime?

  chatbot                  Chatbot                   @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  contact                  Contact                   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages                 Message[]
  conversationParticipants ConversationParticipant[]
  attachment               Attachment[]

  @@index([chatbotId, sourceId])
}

model ConversationParticipant {
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  chatbotId      String
  conversationId String
  userId         String

  chatbot      Chatbot      @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([chatbotId])
  @@index([conversationId])
}

model Message {
  id                String      @id @default(cuid(2))
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  conversationId    String
  inboxId           String
  chatbotId         String
  content           String?
  contentAttributes Json?
  messageType       MessageType
  contentType       ContentType
  senderType        SenderType
  senderId          String?
  sourceId          String?

  chatbot      Chatbot      @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  inbox        Inbox        @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  attachments  Attachment[]

  @@unique([chatbotId, sourceId])
  @@index([chatbotId])
  @@index([conversationId])
  @@index([inboxId])
  @@index([senderType, senderId])
}

model Attachment {
  id             String   @id @default(cuid(2))
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  chatbotId      String
  conversationId String
  fileType       FileType
  messageId      String
  sourceId       String?
  mimeType       String
  width          Int?
  height         Int?
  size           Int      @default(0)
  thumbnailPath  String?
  originPath     String
  name           String?

  chatbot      Chatbot      @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
  @@index([messageId])
}

model Integration {
  id              String          @id @default(cuid(2))
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  chatbotId       String
  integrationType IntegrationType

  openAI       IntegrationOpenAI?
  googleSheets IntegrationGoogleSheets?
  chatbot      Chatbot                  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([chatbotId])
}

model AIAgent {
  id        String   @id @default(cuid(2))
  chatbotId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  prompt    String?
  messages  Json[]

  chatbot            Chatbot             @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integrationOpenAIs IntegrationOpenAI[]
}

model AIAssistant {
  id            String   @id @default(cuid(2))
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  chatbotId     String
  name          String
  prompt        String
  model         String
  aiTriggerIds  String[]
  attachmentIds String[]
  temperature   Float

  chatbot           Chatbot             @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integrationOpenAI IntegrationOpenAI[]
}

model AITrigger {
  id           String   @id @default(cuid(2))
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chatbotId    String
  name         String
  description  String?
  flowId       String?
  questions    Json[]
  finalMessage String?

  chatbot            Chatbot             @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integrationOpenAIs IntegrationOpenAI[]
}

model IntegrationOpenAI {
  id                     String   @id @default(cuid(2))
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  chatbotId              String
  integrationId          String   @unique
  auth                   Json
  automatedResponse      Boolean
  automatedVoiceResponse Boolean  @default(false)
  voice                  String?
  prompt                 String?
  model                  String
  temperature            Float
  maxTokens              Int
  aiAssistantId          String?
  aiAgentId              String?

  chatbot     Chatbot      @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integration Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  aiTriggers  AITrigger[]
  aiAssistant AIAssistant? @relation(fields: [aiAssistantId], references: [id])
  aiAgent     AIAgent?     @relation(fields: [aiAgentId], references: [id])
}

model IntegrationGoogleSheets {
  id            String   @id @default(cuid(2))
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  chatbotId     String
  integrationId String   @unique
  auth          Json

  chatbot     Chatbot     @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model IntegrationWhatsapp {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  inboxId   String   @unique
  auth      Json

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  inbox   Inbox   @relation(fields: [inboxId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model IntegrationChatWidget {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  inboxId   String   @unique
  auth      Json
  name      String

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  inbox   Inbox   @relation(fields: [inboxId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Spreadsheet {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  name      String
  url       String

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model Flow {
  id               String   @id @default(cuid(2))
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  chatbotId        String
  folderId         String?
  name             String
  active           Boolean  @default(true)
  enableInInbox    Boolean  @default(true)
  currentVersionId String?
  draftVersionId   String?

  chatbot      Chatbot       @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  folder       Folder?       @relation(fields: [folderId], references: [id])
  flowVersions FlowVersion[]
  broadcasts   Broadcast[]
}

model FlowVersion {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbotId String
  flowId    String
  nodes     Json
  edges     Json
  isDraft   Boolean

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  flow    Flow    @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

model Broadcast {
  id            String                 @id @default(cuid(2))
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  name          String
  chatbotId     String
  flowId        String
  inboxType     InboxType?
  subaction     BroadcastSubaction?
  status        BroadcastStatus
  schedulesType BroadcastSchedulesType
  schedulesAt   DateTime
  conditions    Json?

  chatbot  Chatbot                @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  flow     Flow                   @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contacts ContactsOnBroadcasts[]

  @@index([chatbotId])
  @@index([flowId])
  @@index([schedulesAt])
}

model ContactsOnBroadcasts {
  broadcastId String
  contactId   String
  sent        Boolean @default(false)
  delivered   Boolean @default(false)
  seen        Boolean @default(false)
  clicked     Boolean @default(false)
  failed      Boolean @default(false)

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([broadcastId, contactId])
}

enum CustomFieldType {
  SHORTTEXT
  NUMBER
  DATE
  DATETIME
  BOOLEAN
  LONGTEXT
}

enum FieldType {
  ACCOUNT_FIELD
  CUSTOM_FIELD
}

enum FolderType {
  TAG
  FLOW
  CUSTOM_FIELD
  EMAIL_CAMPAIGN
  AUTOMATED_RESPONSE
}

enum ChatbotPlan {
  FREE
  PRO
}

enum ChatbotMemberRole {
  OWNER
  AGENT
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum AssignedType {
  USER
  TEAM
}

enum IntegrationType {
  CHAT_WIDGET
  GOOGLE_SHEETS
  INSTAGRAM
  MESSENGER
  OPENAI
  WHATSAPP
}

enum InboxType {
  CHAT_WIDGET
  INSTAGRAM
  MESSENGER
  WHATSAPP
}

enum SenderType {
  BOT
  CONTACT
  SYSTEM
  USER
}

enum MessageType {
  INCOMING
  OUTGOING
  ACTIVITY
}

enum ContentType {
  TEXT
}

enum FileType {
  IMAGE
  AUDIO
  VIDEO
  FILE
}

enum AttachmentType {
  IMAGE
  AUDIO
  VIDEO
  FILE
}

enum BroadcastStatus {
  SCHEDULED
  SENT
}

enum BroadcastSchedulesType {
  NOW
  FUTURE
}

enum BroadcastSubaction {
  TEMPLATE_MESSAGE
  RECENT_CONTACTS
  ALL_CONTACTS
}
