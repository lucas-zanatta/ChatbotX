# Production Environment Variables
APP_ENV=prod

# Dragonfly
DRAGONFLY_PORT=6380
DRAGONFLY_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_MIN_32_CHARS
DRAGONFLY_MAX_MEMORY=8gb
DRAGONFLY_THREADS=8

# Zookeeper
ZOOKEEPER_PORT=2181

# Kafka
KAFKA_EXTERNAL_PORT=9092
KAFKA_INTERNAL_PORT=9093
KAFKA_EXTERNAL_HOST=kafka.example.com
KAFKA_NUM_PARTITIONS=32
KAFKA_MIN_INSYNC_REPLICAS=1

# Kafka Authentication
KAFKA_ADMIN_USER=admin
KAFKA_ADMIN_PASSWORD=CHANGE_THIS_KAFKA_ADMIN_PASSWORD_MIN_32_CHARS
KAFKA_PRODUCER_PASSWORD=CHANGE_THIS_KAFKA_PRODUCER_PASSWORD_MIN_32_CHARS
KAFKA_CONSUMER_PASSWORD=CHANGE_THIS_KAFKA_CONSUMER_PASSWORD_MIN_32_CHARS

# Kafka UI
KAFKA_UI_PORT=8090
KAFKA_UI_USER=admin
KAFKA_UI_PASSWORD=CHANGE_THIS_KAFKA_UI_PASSWORD_MIN_32_CHARS
