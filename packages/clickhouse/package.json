{
  "name": "@chatbotx.io/clickhouse",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@chatbotx.io/flow-config": "workspace:*",
    "@clickhouse/client": "^1.18.2",
    "@t3-oss/env-core": "^0.13.11",
    "date-fns": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chatbotx.io/typescript-config": "workspace:*",
    "@types/node": "^24.10.4",
    "dotenv-cli": "^11.0.0"
  },
  "scripts": {
    "db:migrate": "dotenv -e ../../.env -- tsx src/migrate.ts",
    "db:reset": "dotenv -e ../../.env -v CLICKHOUSE_MIGRATIONS_FORCE=1 -- tsx src/migrate.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./migrate": "./src/migrate.ts",
    "./keys": "./src/keys.ts",
    "./schemas": "./src/schemas.ts",
    "./utils": "./src/utils.ts"
  }
}
