{
  "extends": "@aha.chat/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": [
      "esnext",
      "dom"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@aha.chat/ui/*": [
        "./src/*"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}