# Database Configuration
DATABASE_URL=postgresql://ahachat:your_password@localhost:5432/ahachat
POSTGRES_DB=ahachat
POSTGRES_USER=ahachat
POSTGRES_PASSWORD=your_secure_password

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ahachat
MINIO_SECRET_KEY=your_secure_minio_password
MINIO_ROOT_USER=ahachat
MINIO_ROOT_PASSWORD=your_secure_minio_password

# JWT Configuration
JWT_SECRET=your_very_long_and_secure_jwt_secret_key

# NextAuth Configuration
NEXTAUTH_SECRET=your_very_long_and_secure_nextauth_secret_key
NEXTAUTH_URL=http://localhost:3000

# Environment
NODE_ENV=production

# Asset URL
NEXT_PUBLIC_ASSET_URL=http://localhost:9000

# Sequence Scheduler
DRAGONFLY_HOST=localhost
DRAGONFLY_PORT=6380
DRAGONFLY_PASSWORD=

# Sequence Scheduler - Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_ENABLED=false
KAFKA_CONSUMER_GROUP=sequence-dispatch-consumer

# Sequence Scheduler - Worker Configuration
SCHEDULER_BUCKET_RANGE=0-255
BOOTSTRAP_INTERVAL_MS=3600000
