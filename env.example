# Database Configuration
DATABASE_URL=postgresql://chatbotx:your_password@localhost:5432/chatbotx
POSTGRES_DB=chatbotx
POSTGRES_USER=chatbotx
POSTGRES_PASSWORD=your_secure_password

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=chatbotx
MINIO_SECRET_KEY=your_secure_minio_password
MINIO_ROOT_USER=chatbotx
MINIO_ROOT_PASSWORD=your_secure_minio_password

# JWT Configuration
JWT_SECRET=your_very_long_and_secure_jwt_secret_key

# NextAuth Configuration
NEXTAUTH_SECRET=your_very_long_and_secure_nextauth_secret_key
NEXTAUTH_URL=http://localhost:3000

# Environment
NODE_ENV=production

# Asset URL
NEXT_PUBLIC_ASSET_URL=http://localhost:9000
