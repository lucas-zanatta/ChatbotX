{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "!**/.next",
      "!**/.turbo",
      "!**/packages/database/src/generated/prisma",
      "!**/packages/ui/src/components/data-table",
      "!**/packages/ui/src/components/ui",
      "!**/packages/ui/src/lib",
      "!**/packages/ui/src/hooks",
      "!**/packages/ui/src/components/carousel-snap.tsx",
      "!**/packages/ui/src/types/data-table.ts",
      "!**/apps/builder/src/components/node-header.tsx",
      "!**/apps/builder/src/components/file-dropzone.tsx",
      "!**/dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        },
        "noUnusedVariables": {
          "level": "error",
          "options": {
            "ignoreRestSiblings": true
          }
        },
        "noUnknownProperty": "error"
      },
      "style": {
        "useNodejsImportProtocol": "off",
        "noMagicNumbers": "off"
      },
      "suspicious": {
        "noUnknownAtRules": "off",
        "noDuplicateCustomProperties": "off"
      },
      "complexity": {
        "noExcessiveLinesPerFunction": "off",
        "noExcessiveCognitiveComplexity": "off"
      },
      "performance": {
        "noBarrelFile": "off"
      },
      "nursery": {
        "noLeakedRender": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "extends": ["ultracite/core", "ultracite/next"]
}
